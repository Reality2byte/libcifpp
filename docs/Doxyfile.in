EXCLUDE_SYMBOLS        = cif::detail::*, std*
FILE_PATTERNS          = *.hpp
STRIP_FROM_PATH        = @DOXYGEN_INPUT_DIR@
RECURSIVE              = YES
GENERATE_XML           = YES
GENERATE_LATEX         = NO
PREDEFINED             += and=&& or=|| not=! CIFPP_EXPORT= HAVE_LIBCLIPPER=1
GENERATE_HTML          = NO
GENERATE_TODOLIST      = NO
INPUT                  = @DOXYGEN_INPUT_DIR@


